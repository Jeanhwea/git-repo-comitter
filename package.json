{
  "name": "git-repo-comitter",
  "version": "0.5.4",
  "description": "A CLI tool that uses LLM to generate Git commit messages and execute commits",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "git-repo-comitter": "dist/index.cjs",
    "grc": "dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "lint": "eslint src/",
    "check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky install"
  },
  "keywords": [
    "git",
    "commit",
    "llm",
    "ai",
    "openai"
  ],
  "author": "jeanhwea",
  "license": "unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeanhwea/git-repo-comitter.git"
  },
  "bugs": {
    "url": "https://github.com/Jeanhwea/git-repo-comitter/issues"
  },
  "homepage": "https://github.com/Jeanhwea/git-repo-comitter#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^14.18.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^13.24.0",
    "husky": "^8.0.3",
    "lint-staged": "^12.5.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^4.5.5"
  },
  "dependencies": {
    "commander": "^10.0.0",
    "openai": "^3.3.0",
    "yaml": "^2.9.0"
  }
}
