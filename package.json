{
  "name": "git-repo-comitter",
  "version": "1.0.1",
  "description": "A CLI tool that uses LLM to generate Git commit messages and execute commits",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "git-repo-comitter": "dist/index.cjs",
    "grc": "dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "lint": "eslint src/",
    "check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "keywords": [
    "git",
    "commit",
    "llm",
    "ai",
    "openai"
  ],
  "author": "jeanhwea",
  "license": "unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeanhwea/git-repo-comitter.git"
  },
  "bugs": {
    "url": "https://github.com/Jeanhwea/git-repo-comitter/issues"
  },
  "homepage": "https://github.com/Jeanhwea/git-repo-comitter#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "openai": "^6.46.0",
    "yaml": "^2.9.0"
  }
}
